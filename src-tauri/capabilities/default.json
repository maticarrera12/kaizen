{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/habit-images" },
        { "path": "$APPDATA/habit-images/*" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$APPDATA/habit-images/*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/habit-images" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$APPDATA/habit-images/*" }]
    }
  ]
}
